{
  "info": {
    "name": "PaperlessBoss API - Production",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for production testing of PaperlessBoss APIs including Auth, Company Profile, and Authorised Signatory."
  },
  "item": [
    {
      "name": "Registration & Verification",
      "item": [
        {
          "name": "Register New User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tester_postman@example.com\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Registers a new user account."
          }
        },
        {
          "name": "Verify Email OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tester_postman@example.com\",\n  \"otp_code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "verify-otp"]
            },
            "description": "Validates the 6-digit OTP code."
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tester_postman@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/resend-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "resend-otp"]
            },
            "description": "Resends OTP."
          }
        }
      ]
    },
    {
      "name": "Authentication & Session",
      "item": [
        {
          "name": "User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set(\"access_token\", jsonData.access_token);",
                  "    console.log(\"Saved Access Token to Collection Variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tester_postman@example.com\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Logs in user and returns JWT."
          }
        },
        {
          "name": "Get Profile (Me)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Retrieves session details."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set(\"access_token\", jsonData.access_token);",
                  "    console.log(\"Rotated and Saved Access Token to Collection Variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Uses HttpOnly refresh_token cookie to rotate credentials and fetch a new access token."
          }
        },
        {
          "name": "User Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Logs out the user by deleting their session refresh token from the database and clearing the client-side cookie."
          }
        }
      ]
    },
    {
      "name": "Profile & Signatory Details",
      "item": [
        {
          "name": "Get Company Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/profile/company",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "profile", "company"]
            },
            "description": "Gets Company profile of authenticated user."
          }
        },
        {
          "name": "Create or Update Company Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Technologies Ltd\",\n  \"address\": \"101, Tech Park, Sector 5, Bangalore\",\n  \"gstin\": \"37ABCDE1234F1ZK\",\n  \"pan\": \"ABCDE1234F\",\n  \"cin\": \"L17110MH1973PLC019786\",\n  \"labour_identification_number\": \"LABOUR998877\",\n  \"email\": \"corporate@acme.com\",\n  \"mobile_no\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/profile/company",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "profile", "company"]
            },
            "description": "Upserts Company profile with controls: PAN must match indices 3-12 of GSTIN."
          }
        },
        {
          "name": "Get Authorised Signatory Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/profile/signatory",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "profile", "signatory"]
            },
            "description": "Gets Authorised Signatory details of active user."
          }
        },
        {
          "name": "Create or Update Authorised Signatory Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Johnathan Doe\",\n  \"address\": \"Villa 42, Green Meadows, Bangalore\",\n  \"pan\": \"XYZAB1234C\",\n  \"email\": \"john.doe@acme.com\",\n  \"mobile_no\": \"9876543211\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/profile/signatory",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "profile", "signatory"]
            },
            "description": "Upserts Authorised Signatory profile."
          }
        }
      ]
    },
    {
      "name": "Excel Processing",
      "item": [
        {
          "name": "Validate & Store Excel",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/validate-excel",
              "host": ["{{base_url}}"],
              "path": ["validate-excel"]
            },
            "description": "Uploads and validates a statutory employee records Excel sheet, saving it to a private Supabase bucket and returning a 15-minute secure signed URL on success."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://paperlessboss.com",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ]
}